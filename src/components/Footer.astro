					</svg>
				</a>
				<!-- Facebook -->
				<a href="https://facebook.com" target="_blank" aria-label="Facebook">
					<svg viewBox="0 0 24 24" fill="currentColor">
						<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
					</svg>
				</a>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<span>&copy; {today.getFullYear()} WKND Harvest. All rights reserved.</span>
		<div class="footer-legal">
			<a href="/privacy">Privacy Policy</a>
			<a href="/terms">Terms of Use</a>
			<a href="/cookies">Cookie Policy</a>
		</div>
	</div>
</footer>

<style>
	footer {
		background: #0a0a0a;
		border-top: 2px solid #333;
		padding: 3rem 2rem 1.5rem;
	}
	.footer-top {
		max-width: 1200px;
		margin: 0 auto 2.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
		border-bottom: 1px solid #1a1a1a;
		padding-bottom: 2.5rem;
	}
	@media (max-width: 768px) {
		.footer-top {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.footer-name {
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: 1.1rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #ffffff;
	}
	.footer-tagline {
		font-size: 0.85rem;
		color: #777;
		line-height: 1.5;
		max-width: 320px;
		margin: 0;
	}
	.footer-newsletter h4 {
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 0.3rem;
	}
	.footer-newsletter p {
		font-size: 0.8rem;
		color: #666;
		margin-bottom: 1rem;
	}
	.footer-form {
		display: flex;
		gap: 0.5rem;
	}
	.footer-form input {
		flex: 1;
		background: #161616;
		border: 1px solid #2a2a2a;
		border-radius: 6px;
		padding: 0.6rem 1rem;
		color: #fff;
		font-family: 'Inter', sans-serif;
		outline: none;
		min-width: 200px;
	}
	.footer-form input::placeholder {
		color: #444;
	}
	.footer-form button {
		background: #f5c518;
		color: #000;
		border: none;
		border-radius: 6px;
		padding: 0.6rem 1.2rem;
		font-weight: 700;
		font-size: 0.8rem;
		cursor: pointer;
	}
	.footer-form button:hover {
		background: #e0b015;
	}

	.footer-links {
		max-width: 1200px;
		margin: 0 auto 2.5rem;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
	}
	@media (max-width: 768px) {
		.footer-links {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	.link-col h5 {
		font-family: var(--font-heading);
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #f5c518;
		margin-bottom: 1rem;
	}
	.link-col a {
		display: block;
		color: #888;
		text-decoration: none;
		font-size: 0.6rem;
		padding: 0.3rem 0;
		transition: color 0.2s;
	}
	.link-col a:hover {
		color: #ffffff;
	}

	/* New Social Media Icon Styles */
	.social-icons {
		display: flex;
		gap: 1rem;
		align-items: center;
		padding-top: 0.2rem;
	}
	.social-icons a {
		display: inline-block;
		padding: 0; /* Clear default column link padding */
	}
	.social-icons svg {
		width: 19px;
		height: 19px;
		color: #888; /* Minimal monochrome default */
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.social-icons a:hover svg {
		color: #ffffff; /* Crisp white on hover */
		transform: translateY(-2px); /* Slight lift animation */
	}

	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.5rem;
		border-top: 1px solid #1a1a1a;
		font-size: 0.75rem;
		color: #444;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.footer-legal {
		display: flex;
		gap: 1.5rem;
	}
	.footer-legal a {
		color: #444;
		text-decoration: none;
	}
	.footer-legal a:hover {
		color: #888;
	}
</style>