import HeaderLink from './HeaderLink.astro';
---
<header>
	<div class="top-bar">
		<div class="top-left">
			<a href="/tip" class="top-link">Got a tip?</a>
			<a href="/newsletter" class="top-link">Newsletter</a>
		</div>
		<div class="top-center">
			<a href="/" class="logo-link">
				<img src="/wh-logo.png" alt="WKND Harvest" class="logo-img" />
				<span class="logo-text">WKND Harvest</span>
			</a>
		</div>
		<div class="top-right">
			<a href="/signin" class="top-link">Sign In</a>
			<button class="search-btn" id="searchToggle" aria-label="Search">
				<svg class="icon-search" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="11" cy="11" r="8"></circle>
					<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
				</svg>
				<svg class="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>
		</div>
	</div>

	<nav class="category-nav">
		<div class="nav-item">
			<a href="/blog" class="nav-link">All</a>
		</div>
		
		<!-- AI & TECH -->
		<div class="nav-item has-dropdown">
			<a href="/tech" class="nav-link">AI & Tech</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/tech/ai-news">AI News</a>
					<a href="/tech/gadgets">Gadgets</a>
					<a href="/tech/apps">Apps</a>
					<a href="/tech/cybersecurity">Cybersecurity</a>
					<a href="/tech/space-tech">Space Tech</a>
					<a href="/tech/future-of-work">Future of Work</a>
				</div>
			</div>
		</div>

		<!-- SHOPPING -->
		<div class="nav-item has-dropdown">
			<a href="/shopping" class="nav-link">Shopping</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/shopping/deals">Deals</a>
					<a href="/shopping/gift-guides">Gift Guides</a>
					<a href="/shopping/style-picks">Style Picks</a>
					<a href="/shopping/gadgets">Gadgets</a>
					<a href="/shopping/home-finds">Home Finds</a>
				</div>
			</div>
		</div>

		<!-- TRAVEL -->
		<div class="nav-item has-dropdown">
			<a href="/travel" class="nav-link">Travel</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/travel/destinations">Destinations</a>
					<a href="/travel/budget-travel">Budget Travel</a>
					<a href="/travel/luxury-travel">Luxury Travel</a>
					<a href="/travel/travel-hacks">Travel Hacks</a>
					<a href="/travel/visa-guides">Visa Guides</a>
				</div>
			</div>
		</div>

		<!-- HEALTH -->
		<div class="nav-item has-dropdown">
			<a href="/health" class="nav-link">Health</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/health/mental-health">Mental Health</a>
					<a href="/health/fitness">Fitness</a>
					<a href="/health/nutrition">Nutrition</a>
					<a href="/health/sleep">Sleep</a>
					<a href="/health/longevity">Longevity</a>
				</div>
			</div>
		</div>

		<!-- FAMILY -->
		<div class="nav-item has-dropdown">
			<a href="/family" class="nav-link">Family</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/family/home">Home</a>
					<a href="/family/parenting">Parenting</a>
					<a href="/family/relationships">Relationships</a>
					<a href="/family/kids">Kids</a>
					<a href="/family/marriage">Marriage</a>
				</div>
			</div>
		</div>

		<!-- SPORTS -->
		<div class="nav-item has-dropdown">
			<a href="/sports" class="nav-link">Sports</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/sports/football">Football</a>
					<a href="/sports/basketball">Basketball</a>
					<a href="/sports/tennis">Tennis</a>
					<a href="/sports/combat-sports">Combat Sports</a>
					<a href="/sports/motorsport">Motorsport</a>
				</div>
			</div>
		</div>

		<!-- LIFESTYLE -->
		<div class="nav-item has-dropdown">
			<a href="/lifestyle" class="nav-link">Lifestyle</a>
			<div class="mega-menu">
				<div class="mega-links">
					<a href="/lifestyle/style">Style</a>
					<a href="/lifestyle/food">Food</a>
					<a href="/lifestyle/culture">Culture</a>
					<a href="/lifestyle/music">Music</a>
					<a href="/lifestyle/home-decor">Home Decor</a>
				</div>
			</div>
		</div>
	</nav>

	<div class="search-bar" id="searchBar">
		<div class="search-inner">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2">
				<circle cx="11" cy="11" r="8"></circle>
				<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
			</svg>
			<input type="text" placeholder="Search WKND Harvest..." class="search-input" id="searchInput" />
			<button class="search-close" id="searchClose">✕</button>
		</div>
	</div>
</header>
<div class="search-overlay" id="searchOverlay"></div>

<script>
	const toggle = document.getElementById('searchToggle');
	const bar = document.getElementById('searchBar');
	const closeBtn = document.getElementById('searchClose');
	const input = document.getElementById('searchInput');
	const overlay = document.getElementById('searchOverlay');
	const iconSearch = toggle.querySelector('.icon-search');
	const iconClose = toggle.querySelector('.icon-close');

	function openSearch() {
		bar.classList.add('open');
		overlay.classList.add('open');
		iconSearch.style.display = 'none';
		iconClose.style.display = 'block';
		input.focus();
	}
	function closeSearch() {
		bar.classList.remove('open');
		overlay.classList.remove('open');
		iconSearch.style.display = 'block';
		iconClose.style.display = 'none';
	}
	toggle.addEventListener('click', () => {
		bar.classList.contains('open') ? closeSearch() : openSearch();
	});
	closeBtn.addEventListener('click', closeSearch);
	overlay.addEventListener('click', closeSearch);
</script>

<style>
	header {
		background: #0a0a0a;
		border-bottom: 2px solid #333;
		position: sticky;
		top: 0;
		z-index: 100;
		margin-bottom: 2rem;
	}
	.top-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid #1a1a1a;
		position: relative;
		min-height: 100px;
	}
	.top-left {
		display: flex;
		gap: 1.2rem;
		align-items: center;
	}
	.top-center {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3rem;
	}
	.top-right {
		display: flex;
		gap: 1.2rem;
		align-items: center;
		justify-content: flex-end;
	}
	.logo-link {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-decoration: none;
		gap: 0.3rem;
	}
	.logo-img {
		height: 48px;
		width: auto;
		border-radius: 0;
	}
	.logo-text {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 800;
		font-size: 0.72rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #ffffff;
	}
	.top-link {
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #aaaaaa;
		text-decoration: none;
		transition: color 0.2s;
	}
	.top-link:hover {
		color: #ffffff;
	}
	.search-btn {
		background: none;
		border: none;
		color: #aaaaaa;
		cursor: pointer;
		padding: 0;
		display: flex;
		align-items: center;
		transition: color 0.2s;
	}
	.search-btn:hover {
		color: #ffffff;
	}

	/* Category nav */
	.category-nav {
		display: flex;
		justify-content: center;
		padding: 0 2rem;
		border-bottom: 1px solid #1a1a1a;
		position: static; /* Allows menu layout to read full header width */
	}
	.nav-item {
		position: static; /* Allows menu width to stretch past text boundaries */
	}
	.nav-link {
		display: block;
		padding: 0.75rem 1.1rem;
		color: #aaaaaa;
		text-decoration: none;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		border-bottom: 2px solid transparent;
		white-space: nowrap;
		transition: color 0.2s, border-bottom-color 0.2s;
	}
	.nav-link:hover,
	.nav-link.active {
		color: #f5c518;
		border-bottom-color: #f5c518;
	}

	/* Wide horizontal breakout mega menu */
	.mega-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		width: 100%;
		box-sizing: border-box;
		background: #111111;
		border-bottom: 2px solid #f5c518;
		padding: 1.2rem 2rem;
		z-index: 200;
		box-shadow: 0 8px 32px rgba(0,0,0,0.6);
	}
	.has-dropdown:hover .mega-menu {
		display: block;
	}
	
	/* Horizontal links alignment layout */
	.mega-links {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 3.5rem; /* Generous wide look space between subtopics */
		width: 100%;
	}
	.mega-links a {
		font-size: 0.75rem;
		color: #aaaaaa;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 700;
		letter-spacing: 0.08em;
		transition: color 0.2s;
	}
	.mega-links a:hover {
		color: #f5c518; /* Accents matching your system theme */
	}

	/* Search bar */
	.search-bar {
		display: none;
		position: relative;
		z-index: 101;
		background: #1a1a1a;
		border-bottom: 1px solid #2a2a2a;
	}
	.search-bar.open {
		display: block;
	}
	.search-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 0.8rem 2rem;
	}
	.search-input {
		width: 50%;
		max-width: 600px;
		background: #2a2a2a;
		border: 1px solid #3a3a3a;
		border-radius: 6px;
		padding: 0.6rem 1rem;
		color: #ffffff;
		font-size: 0.9rem;
		font-family: 'Inter', sans-serif;
		outline: none;
		transition: border-color 0.2s;
	}
	.search-input:focus {
		border-color: #555;
	}
	.search-input::placeholder {
		color: #555;
	}
	.search-close {
		background: none;
		border: none;
		color: #555;
		cursor: pointer;
		font-size: 1rem;
		transition: color 0.2s;
	}
	.search-close:hover {
		color: #ffffff;
	}
	.search-overlay {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0,0,0,0.7);
		z-index: 99;
	}
	.search-overlay.open {
		display: block;
	}

	@media (max-width: 720px) {
		.top-bar {
			padding: 1rem;
			min-height: 80px;
		}
		.top-left {
			gap: 0.8rem;
		}
		.top-link {
			font-size: 0.65rem;
		}
		.category-nav {
			padding: 0 0.5rem;
			justify-content: flex-start;
			overflow-x: auto; /* Restored safely for mobile slide swiping rows */
		}
		.nav-link {
			padding: 0.6rem 0.7rem;
			font-size: 0.65rem;
		}
		.mega-menu {
			display: none !important; /* Hides giant bars cleanly on tiny touch mobile viewports */
		}
		.search-input {
			width: 85%;
		}
	}
</style>