---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`DMCA | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-layout">
			<h1>DMCA / Copyright</h1>
			<p class="updated">Last updated: June 16, 2026</p>

			<section class="policy-section">
				<h2>Copyright Policy</h2>
				<p>WKND Harvest respects intellectual property rights. All content published on this site is either original, properly licensed, or used under fair use principles for commentary and news reporting.</p>
			</section>

			<section class="policy-section">
				<h2>Reporting Infringement</h2>
				<p>If you believe your copyrighted work has been used on WKND Harvest without authorization, please send a detailed notice to <a href="mailto:hello@wkndharvest.com">hello@wkndharvest.com</a> including:</p>
				<ul>
					<li>Your contact information</li>
					<li>Description of the copyrighted work</li>
					<li>URL of the infringing material on our site</li>
					<li>A statement that you believe the use is not authorized</li>
					<li>A statement that the information is accurate, under penalty of perjury</li>
				</ul>
			</section>

			<section class="policy-section">
				<h2>Counter-Notification</h2>
				<p>If you believe your content was removed in error, you may submit a counter-notification with the same level of detail.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-layout {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem;
		color: #d0d0d0;
		font-size: 1rem;
		line-height: 1.8;
	}
	.page-layout h1 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 0.5rem;
		letter-spacing: -0.03em;
	}
	.updated {
		font-size: 0.85rem;
		color: #555;
		margin-bottom: 3rem;
	}
	.policy-section {
		margin-bottom: 2.5rem;
	}
	.policy-section h2 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.2rem;
		font-weight: 800;
		color: #f5c518;
		margin-bottom: 1rem;
	}
	.policy-section ul {
		padding-left: 1.5rem;
		margin-bottom: 1rem;
	}
	.policy-section li {
		margin-bottom: 0.5rem;
	}
	.policy-section a {
		color: #f5c518;
		text-decoration: none;
	}
	.policy-section a:hover {
		text-decoration: underline;
	}
</style>