---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Cookie Policy | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-layout">
			<h1>Cookie Policy</h1>
			<p class="updated">Last updated: June 16, 2026</p>

			<section class="policy-section">
				<h2>What Are Cookies?</h2>
				<p>Cookies are small text files stored on your device when you visit websites. They help sites remember your preferences and improve your experience.</p>
			</section>

			<section class="policy-section">
				<h2>How We Use Cookies</h2>
				<p>WKND Harvest uses minimal cookies:</p>
				<ul>
					<li><strong>Essential cookies:</strong> Required for the site to function properly (e.g., Cloudflare security)</li>
					<li><strong>Preference cookies:</strong> Remember your settings if applicable</li>
				</ul>
				<p>We do not use tracking cookies, advertising cookies, or analytics cookies that identify you personally.</p>
			</section>

			<section class="policy-section">
				<h2>Managing Cookies</h2>
				<p>You can disable cookies in your browser settings. Note that some site features may not work properly without essential cookies.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-layout {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem;
		color: #d0d0d0;
		font-size: 1rem;
		line-height: 1.8;
	}
	.page-layout h1 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 0.5rem;
		letter-spacing: -0.03em;
	}
	.updated {
		font-size: 0.85rem;
		color: #555;
		margin-bottom: 3rem;
	}
	.policy-section {
		margin-bottom: 2.5rem;
	}
	.policy-section h2 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.2rem;
		font-weight: 800;
		color: #f5c518;
		margin-bottom: 1rem;
	}
	.policy-section ul {
		padding-left: 1.5rem;
		margin-bottom: 1rem;
	}
	.policy-section li {
		margin-bottom: 0.5rem;
	}
</style>