---
const today = new Date();
---

<footer>
	<div class="footer-top">
		<div class="footer-brand">
			<span class="footer-name">WKND Harvest</span>
			<p class="footer-tagline">Your weekly harvest of what matters — tech, travel, health, money, sports, and life.</p>
		</div>
		
		<div class="footer-newsletter">
			<h4>The Weekly Harvest</h4>
			<p>One email. Every Sunday. No spam.</p>
			<form class="footer-form" action="/newsletter" method="POST">
				<input type="email" placeholder="your@email.com" required />
				<button type="submit">Join</button>
			</form>
		</div>
	</div>

	<div class="footer-links">
		<div class="link-col">
			<h5>Sections</h5>
			<a href="/tech">AI & Tech</a>
			<a href="/shopping">Shopping</a>
			<a href="/travel">Travel</a>
			<a href="/health">Health</a>
			<a href="/family">Family</a>
			<a href="/sports">Sports</a>
			<a href="/lifestyle">Lifestyle</a>
		</div>
		<div class="link-col">
			<h5>Company</h5>
			<a href="/about">About Us</a>
			<a href="/careers">Careers</a>
			<a href="/advertise">Advertise</a>
			<a href="/events">Events & Promotions</a>
			<a href="/community">Community Guidelines</a>
		</div>
		<div class="link-col">
			<h5>Support</h5>
			<a href="/contact">Contact Us</a>
			<a href="/tip">Got a Tip?</a>
			<a href="/newsletter">Newsletter</a>
			<a href="/dmca">DMCA</a>
			<a href="/customer-service">Customer Service</a>
		</div>
		<div class="link-col">
			<h5>Follow</h5>
			<div class="social-icons">
				<!-- TikTok -->
				<a href="https://tiktok.com/@SSlaoui" target="_blank" aria-label="TikTok">
					<svg viewBox="0 0 24 24" fill="currentColor">
						<path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.02 1.63 4.14 1.13 1.18 2.7 1.86 4.34 2.01v3.91a8.91 8.91 0 01-4.16-1.12c-.52-.3-.99-.68-1.4-1.11v6.95a7.84 7.84 0 01-1.78 4.95 7.69 7.69 0 01-11.45.6 7.94 7.94 0 01-1.63-7.44c.5-1.9 1.76-3.53 3.48-4.47a7.7 7.7 0 017.06-.23v4.06a3.81 3.81 0 00-2.31 1c-1.39 1.34-1.42 3.61-.08 4.99a3.83 3.83 0 005.47-.04c.73-.78 1.07-1.85 1.01-2.91V.02z"/>
					</svg>
				</a>
				<!-- X / Twitter -->
				<a href="https://twitter.com" target="_blank" aria-label="X (formerly Twitter)">
