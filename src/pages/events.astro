---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Events & Promotions | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-layout">
			<h1>Events & Promotions</h1>
			<p class="lead">Partner with WKND Harvest on events, giveaways, and exclusive promotions.</p>

			<section class="policy-section">
				<h2>Current Promotions</h2>
				<p>No active promotions right now. Check back soon or subscribe to The Weekly Harvest to be first to know.</p>
			</section>

			<section class="policy-section">
				<h2>Partner With Us</h2>
				<p>Interested in co-hosting an event or running a promotion with WKND Harvest? Email <a href="mailto:hello@wkndharvest.com">hello@wkndharvest.com</a> with your proposal.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-layout {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem;
		color: #d0d0d0;
		font-size: 1rem;
		line-height: 1.8;
	}
	.page-layout h1 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 1rem;
		letter-spacing: -0.03em;
	}
	.lead {
		font-size: 1.15rem;
		color: #888;
		margin-bottom: 3rem;
		line-height: 1.6;
	}
	.policy-section {
		margin-bottom: 2.5rem;
	}
	.policy-section h2 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.2rem;
		font-weight: 800;
		color: #f5c518;
		margin-bottom: 1rem;
	}
	.policy-section a {
		color: #f5c518;
		text-decoration: none;
	}
	.policy-section a:hover {
		text-decoration: underline;
	}
</style>