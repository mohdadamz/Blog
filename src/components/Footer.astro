---
const today = new Date();
---
<footer>
	<div class="footer-top">
		<div class="footer-brand">
			<a href="/" class="brand-link">
				<img src="/wh-logo.png" alt="WKND Harvest" class="footer-logo" />
				<span class="footer-name">WKND Harvest</span>
			</a>
			<p class="footer-tagline">Your weekly harvest of what matters — tech, travel, health, money, sports, and life.</p>
			<div class="footer-social">
				<a href="https://tiktok.com/@SSlaoui" target="_blank">TikTok</a>
				<a href="https://twitter.com" target="_blank">X / Twitter</a>
				<a href="https://instagram.com" target="_blank">Instagram</a>
				<a href="/rss.xml">RSS</a>
			</div>
		</div>

		<div class="footer-newsletter">
			<span class="newsletter-eyebrow">Free · Weekly · No Spam</span>
			<h4>The Weekly Harvest</h4>
			<p>One email. Every Sunday. The best stories we found — curated, not generated.</p>
			<form class="footer-form" action="/newsletter" method="POST">
				<input type="email" placeholder="your@email.com" required />
				<button type="submit">Subscribe Free</button>
			</form>
		</div>
	</div>

	<div class="footer-links">
		<div class="link-col">
			<h5>Sections</h5>
			<a href="/tech">AI & Tech</a>
			<a href="/shopping">Shopping</a>
			<a href="/travel">Travel</a>
			<a href="/health">Health</a>
			<a href="/family">Family</a>
			<a href="/sports">Sports</a>
			<a href="/lifestyle">Lifestyle</a>
		</div>
		<div class="link-col">
			<h5>Company</h5>
			<a href="/about">About Us</a>
			<a href="/careers">Careers</a>
			<a href="/advertise">Advertise with Us</a>
			<a href="/events">Events & Promotions</a>
			<a href="/community">Community Guidelines</a>
		</div>
		<div class="link-col">
			<h5>Support</h5>
			<a href="/contact">Contact Us</a>
			<a href="/tip">Got a Tip?</a>
			<a href="/newsletter">Newsletter</a>
			<a href="/dmca">DMCA</a>
			<a href="/privacy">Privacy Policy</a>
			<a href="/terms">Terms of Use</a>
		</div>
		<div class="link-col">
			<h5>Follow Us</h5>
			<a href="https://tiktok.com/@SSlaoui" target="_blank">TikTok</a>
			<a href="https://twitter.com" target="_blank">X / Twitter</a>
			<a href="https://instagram.com" target="_blank">Instagram</a>
			<a href="/rss.xml">RSS Feed</a>
		</div>
	</div>

	<div class="footer-bottom">
		<span>&copy; {today.getFullYear()} WKND Harvest. All rights reserved.</span>
		<div class="footer-legal">
			<a href="/privacy">Privacy Policy</a>
			<a href="/terms">Terms of Use</a>
			<a href="/dmca">DMCA</a>
			<a href="/cookies">Cookie Policy</a>
		</div>
	</div>
</footer>

<style>
	footer {
		background: #080808;
		border-top: 2px solid #f5c518;
		margin-top: 4rem;
	}

	/* TOP ROW — brand + newsletter */
	.footer-top {
		max-width: 1280px;
		margin: 0 auto;
		padding: 3rem 2rem 2.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		border-bottom: 1px solid #1a1a1a;
	}
	@media (max-width: 768px) {
		.footer-top { grid-template-columns: 1fr; gap: 2rem; }
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.brand-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
	}
	.footer-logo {
		height: 38px;
		width: auto;
		border-radius: 0 !important;
	}
	.footer-name {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 800;
		font-size: 0.9rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #ffffff;
	}
	.footer-tagline {
		font-size: 0.83rem;
		color: #555;
		line-height: 1.6;
		max-width: 340px;
		margin: 0;
	}
	.footer-social {
		display: flex;
		gap: 1.2rem;
		margin-top: 0.25rem;
	}
	.footer-social a {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #444;
		text-decoration: none;
		transition: color 0.2s;
	}
	.footer-social a:hover { color: #f5c518; }

	/* Newsletter */
	.footer-newsletter {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.newsletter-eyebrow {
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #f5c518;
	}
	.footer-newsletter h4 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.3rem;
		font-weight: 800;
		color: #ffffff;
		margin: 0;
		letter-spacing: -0.01em;
	}
	.footer-newsletter p {
		font-size: 0.82rem;
		color: #555;
		margin: 0 0 0.5rem 0;
		line-height: 1.5;
	}
	.footer-form {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.footer-form input {
		flex: 1;
		min-width: 200px;
		background: #111;
		border: 1px solid #222;
		border-radius: 6px;
		padding: 0.65rem 1rem;
		color: #fff;
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem;
		outline: none;
		transition: border-color 0.2s;
	}
	.footer-form input:focus { border-color: #333; }
	.footer-form input::placeholder { color: #333; }
	.footer-form button {
		background: #f5c518;
		color: #000;
		border: none;
		border-radius: 6px;
		padding: 0.65rem 1.5rem;
		font-weight: 800;
		font-size: 0.8rem;
		cursor: pointer;
		letter-spacing: 0.04em;
		transition: background 0.2s, transform 0.1s;
		white-space: nowrap;
	}
	.footer-form button:hover {
		background: #e0b015;
		transform: translateY(-1px);
	}

	/* LINKS ROW */
	.footer-links {
		max-width: 1280px;
		margin: 0 auto;
		padding: 2.5rem 2rem;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		border-bottom: 1px solid #1a1a1a;
	}
	@media (max-width: 768px) {
		.footer-links { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 480px) {
		.footer-links { grid-template-columns: 1fr; }
	}
	.link-col h5 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #f5c518;
		margin: 0 0 1rem 0;
		padding-bottom: 0.6rem;
		border-bottom: 1px solid #1a1a1a;
	}
	.link-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.link-col a {
		color: #555;
		text-decoration: none;
		font-size: 0.82rem;
		padding: 0.15rem 0;
		transition: color 0.2s;
		line-height: 1.4;
	}
	.link-col a:hover { color: #ffffff; }

	/* BOTTOM BAR */
	.footer-bottom {
		max-width: 1280px;
		margin: 0 auto;
		padding: 1.25rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
		font-size: 0.72rem;
		color: #333;
	}
	.footer-legal {
		display: flex;
		gap: 1.5rem;
	}
	.footer-legal a {
		color: #333;
		text-decoration: none;
		transition: color 0.2s;
	}
	.footer-legal a:hover { color: #888; }
</style>