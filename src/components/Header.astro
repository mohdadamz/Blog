---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Articles</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://tiktok.com/@SSlaoui" target="_blank">
				<span class="sr-only">Follow on TikTok</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0a0a0a;
		box-shadow: 0 2px 8px rgba(0,0,0,0.4);
	}
	h2 {
		margin: 0;
		font-size: 1.1em;
		font-weight: 800;
		letter-spacing: -0.02em;
		text-transform: uppercase;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #ffffff;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
	}
	nav a {
		padding: 1em 0.5em;
		color: #aaaaaa;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.85em;
		font-weight: 500;
		letter-spacing: 0.03em;
		text-transform: uppercase;
	}
	nav a.active {
		text-decoration: none;
		color: #ffffff;
		border-bottom-color: #ffffff;
	}
	.social-links,
	.social-links a {
		display: flex;
		color: #aaaaaa;
	}
	.social-links a:hover {
		color: #ffffff;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>