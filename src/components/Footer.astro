---
const today = new Date();
---
<footer>
	<div class="footer-inner">
		<span class="brand">WKND Harvest</span>
		<span class="copy">&copy; {today.getFullYear()} All rights reserved.</span>
		<div class="social-links">
			<a href="https://tiktok.com/@SSlaoui" target="_blank">
				<span class="sr-only">Follow on TikTok</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"
					></path></svg
				>
			</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em;
		background: #0a0a0a;
		border-top: 1px solid #222;
	}
	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		flex-wrap: wrap;
		gap: 1em;
	}
	.brand {
		font-weight: 800;
		font-size: 0.95em;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #ffffff;
	}
	.copy {
		font-size: 0.8em;
		color: #555;
	}
	.social-links {
		display: flex;
		gap: 1em;
	}
	.social-links a {
		color: #555;
		text-decoration: none;
	}
	.social-links a:hover {
		color: #ffffff;
	}
</style>