---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Newsletter | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-layout">
			<div class="newsletter-hero">
				<span class="eyebrow">The Weekly Harvest</span>
				<h1>One Email. Every Sunday. Zero Noise.</h1>
				<p class="lead">We read hundreds of sources so you don't have to. Every Sunday, we send you the 5 best stories we found — curated by humans, not algorithms.</p>

				<form class="nl-form" action="/newsletter" method="POST">
					<input type="email" placeholder="your@email.com" required />
					<button type="submit">Subscribe Free</button>
				</form>
				<p class="nl-note">No spam. Unsubscribe anytime. We respect your inbox.</p>
			</div>

			<section class="nl-features">
				<div class="nl-feature">
					<h3>Curated, Not Generated</h3>
					<p>Every story is hand-picked by our editors. No AI summaries. No content farms.</p>
				</div>
				<div class="nl-feature">
					<h3>Global Perspective</h3>
					<p>We pull from sources in English, Arabic, French, and Spanish. You get stories others miss.</p>
				</div>
				<div class="nl-feature">
					<h3>Actionable Intel</h3>
					<p>Not just what happened — why it matters and what you should do about it.</p>
				</div>
			</section>

			<section class="nl-past">
				<h2>What You Missed Last Week</h2>
				<div class="past-list">
					<article class="past-item">
						<span class="past-tag">AI & Tech</span>
						<h4>Why Your Next Boss Might Be an AI Agent</h4>
					</article>
					<article class="past-item">
						<span class="past-tag">Travel</span>
						<h4>The Real Morocco Nobody Shows on Instagram</h4>
					</article>
					<article class="past-item">
						<span class="past-tag">Money</span>
						<h4>Why UAE Workers Save More Than Germans Earning Twice the Salary</h4>
					</article>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-layout {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem;
		color: #d0d0d0;
		font-size: 1rem;
		line-height: 1.8;
	}
	.newsletter-hero {
		text-align: center;
		padding: 3rem 0 4rem;
		border-bottom: 1px solid #1a1a1a;
		margin-bottom: 3rem;
	}
	.eyebrow {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #f5c518;
		display: block;
		margin-bottom: 1rem;
	}
	.newsletter-hero h1 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 5vw, 3.2rem);
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 1rem;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}
	.lead {
		font-size: 1.1rem;
		color: #888;
		margin-bottom: 2rem;
		line-height: 1.6;
		max-width: 560px;
		margin-left: auto;
		margin-right: auto;
	}
	.nl-form {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 1rem;
	}
	.nl-form input {
		background: #111;
		border: 1px solid #222;
		border-radius: 6px;
		padding: 0.85rem 1.25rem;
		color: #fff;
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		min-width: 280px;
		outline: none;
		transition: border-color 0.2s;
	}
	.nl-form input:focus { border-color: #f5c518; }
	.nl-form input::placeholder { color: #444; }
	.nl-form button {
		background: #f5c518;
		color: #000;
		border: none;
		border-radius: 6px;
		padding: 0.85rem 2rem;
		font-weight: 800;
		font-size: 0.9rem;
		cursor: pointer;
		letter-spacing: 0.04em;
		transition: background 0.2s, transform 0.1s;
	}
	.nl-form button:hover {
		background: #e0b015;
		transform: translateY(-1px);
	}
	.nl-note {
		font-size: 0.8rem;
		color: #444;
		margin: 0;
	}
	.nl-features {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-bottom: 3rem;
	}
	@media (max-width: 768px) {
		.nl-features { grid-template-columns: 1fr; }
	}
	.nl-feature h3 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1rem;
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 0.5rem;
	}
	.nl-feature p {
		font-size: 0.9rem;
		color: #666;
		line-height: 1.6;
		margin: 0;
	}
	.nl-past h2 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.2rem;
		font-weight: 800;
		color: #f5c518;
		margin-bottom: 1.5rem;
	}
	.past-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.past-item {
		padding: 1rem 0;
		border-bottom: 1px solid #1a1a1a;
	}
	.past-tag {
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #f5c518;
		display: block;
		margin-bottom: 0.3rem;
	}
	.past-item h4 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1rem;
		font-weight: 700;
		color: #d0d0d0;
		margin: 0;
	}
</style>