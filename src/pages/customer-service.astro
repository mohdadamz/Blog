---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Customer Service | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-layout">
			<h1>Customer Service</h1>
			<p class="lead">We're here to help with any issues related to your WKND Harvest experience.</p>

			<section class="policy-section">
				<h2>Common Questions</h2>
				<p><strong>I subscribed to the newsletter but I'm not receiving emails.</strong><br>Check your spam folder first. If it's not there, email us and we'll investigate.</p>
				<p><strong>How do I unsubscribe?</strong><br>Click the "Unsubscribe" link at the bottom of any newsletter email.</p>
				<p><strong>I found a broken link or error on the site.</strong><br>Let us know via the <a href="/contact">Contact page</a> and we'll fix it.</p>
			</section>

			<section class="policy-section">
				<h2>Still Need Help?</h2>
				<p>Email us at <a href="mailto:hello@wkndharvest.com">hello@wkndharvest.com</a>. We typically respond within 24-48 hours.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-layout {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem;
		color: #d0d0d0;
		font-size: 1rem;
		line-height: 1.8;
	}
	.page-layout h1 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 1rem;
		letter-spacing: -0.03em;
	}
	.lead {
		font-size: 1.15rem;
		color: #888;
		margin-bottom: 3rem;
		line-height: 1.6;
	}
	.policy-section {
		margin-bottom: 2.5rem;
	}
	.policy-section h2 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 1.2rem;
		font-weight: 800;
		color: #f5c518;
		margin-bottom: 1rem;
	}
	.policy-section p {
		margin-bottom: 1.2rem;
	}
	.policy-section a {
		color: #f5c518;
		text-decoration: none;
	}
	.policy-section a:hover {
		text-decoration: underline;
	}
</style>